# Vorlage für den MQTT-Stack (docker-compose-mqtt.yml).
# Kopieren nach .env.mqtt und Werte anpassen:  cp .env.mqtt.example .env.mqtt
# .env.mqtt ist gitignored (keine Secrets committen).

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Anthropic API Key (nur für KI-Einheiten-Matching beim CSV-Upload; für den MQTT-Test optional)
ANTHROPIC_API_KEY=

# Broker-User: werden beim Start des mosquitto-Containers in die passwd gehasht
# (user:passwort-Paare, whitespace-getrennt; Passwörter ohne Whitespace).
# Muss den Backend-Subscriber (MQTT_BROKER_USERNAME/PASSWORD unten) und – sobald ein
# Pi publiziert – den Publisher-User des Pi (MQTT_USERNAME/PASSWORD in /etc/pi-gateway.env)
# enthalten. NICHT produktiv verwenden – eigene Passwörter setzen.
MOSQUITTO_USERS=zev-backend:zev-mqtt-dev pi-org42:change-me

# MQTT-Broker (nur bei aktivem Spring-Profil 'mqtt', SPRING_PROFILES_ACTIVE=mqtt).
# Im Docker-Stack (docker-compose-mqtt.yml) wird MQTT_BROKER_URL fest auf tcp://mosquitto:1883
# gesetzt. Der Broker erzwingt Auth; die folgenden Dev-Credentials müssen einem Eintrag in
# MOSQUITTO_USERS entsprechen. NICHT produktiv verwenden.
# Für einen externen Broker (z.B. NAS) MQTT_BROKER_URL setzen und eigene Credentials eintragen:
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_BROKER_USERNAME=zev-backend
MQTT_BROKER_PASSWORD=zev-mqtt-dev
# Optionale Feineinstellungen (Defaults in backend-service/.../application-mqtt.yml):
#MQTT_CLIENT_ID=zev-backend-subscriber
#MQTT_TOPIC=zev/+/+/messwert
#MQTT_QOS=1

# Laufzeit-Config des Angular-Frontends (via FrontendConfigController als /assets/config.json).
# Lokal: localhost. Für das NAS auf den öffentlichen Host setzen, den der BROWSER verwendet,
# z.B. FRONTEND_KEYCLOAK_URL=http://nasnafam.synology.me:9000 (bzw. https ohne Port bei Reverse-Proxy).
FRONTEND_API_BASE_URL=http://nasnafam.synology.me:8090
FRONTEND_KEYCLOAK_URL=http://nasnafam.synology.me:9000
FRONTEND_KEYCLOAK_REALM=zev
FRONTEND_KEYCLOAK_CLIENT_ID=zev-frontend

# --- NAS: öffentlicher Host für Keycloak/Redirects -------------------------------
# Alle folgenden auf DENSELBEN Host setzen wie FRONTEND_KEYCLOAK_URL / FRONTEND_*
# (der Host, den der Browser verwendet). Lokal können sie weggelassen werden (Defaults).
#
# Backend: iss-Claim-Prüfung (muss zum Token-Issuer passen):
APP_CORS_ALLOWED_ORIGINS=http://10.8.0.1:4200
BACKEND_JWT_ISSUER_URI=http://nasnafam.synology.me:9000/realms/zev
# Frontend-URL für die Redirect-/WebOrigin-Whitelist des Clients (zev-realm.json):
ZEV_FRONTEND_URL=http://nasnafam.synology.me:4200
# Nur hinter einem (HTTPS-)Reverse-Proxy nötig (dann VOLLE URL inkl. Schema, siehe Compose):
#KC_HOSTNAME=https://nasnafam.synology.me
#KC_PROXY_HEADERS=xforwarded

# Mosquitto-Broker mit gebackener Config, aber OHNE eingebackene passwd:
# Die Zugangsdaten werden beim Container-Start aus der Umgebung (MOSQUITTO_USERS)
# generiert -> keine Secrets im Image oder im Repo.
# Einschraenkung: Passwoerter duerfen keinen Whitespace enthalten (Wort-Splitting).
# Ein Doppelpunkt im Passwort ist erlaubt (nur der erste trennt user/passwort).
MOSQUITTO_USERS=zev-backend:zev-mqtt-dev