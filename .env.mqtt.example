# Vorlage für den MQTT-Stack (docker-compose-mqtt.yml).
# Kopieren nach .env.mqtt und Werte anpassen:  cp .env.mqtt.example .env.mqtt
# .env.mqtt ist gitignored (keine Secrets committen).

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Anthropic API Key (nur für KI-Einheiten-Matching beim CSV-Upload; für den MQTT-Test optional)
ANTHROPIC_API_KEY=

# MQTT-Broker (nur bei aktivem Spring-Profil 'mqtt', SPRING_PROFILES_ACTIVE=mqtt).
# Im Docker-Stack (docker-compose-mqtt.yml) wird MQTT_BROKER_URL fest auf tcp://mosquitto:1883
# gesetzt. Der Dev-Broker erzwingt Auth (passwd-Datei); die folgenden Dev-Credentials passen
# zu pi-gateway/deploy/mosquitto/passwd. NICHT produktiv verwenden.
# Für einen externen Broker (z.B. NAS) MQTT_BROKER_URL setzen und eigene Credentials eintragen:
#MQTT_BROKER_URL=tcp://nas.local:1883
MQTT_BROKER_USERNAME=zev-backend
MQTT_BROKER_PASSWORD=zev-mqtt-dev
# Optionale Feineinstellungen (Defaults in backend-service/.../application-mqtt.yml):
#MQTT_CLIENT_ID=zev-backend-subscriber
#MQTT_TOPIC=zev/+/+/messwert
#MQTT_QOS=1
