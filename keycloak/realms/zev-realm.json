{
    "realm": "zev",
    "enabled": true,
    "organizationsEnabled": true,
    "clients": [
        {
            "clientId": "zev-frontend",
            "enabled": true,
            "publicClient": true,
            "standardFlowEnabled": true,
            "implicitFlowEnabled": false,
            "directAccessGrantsEnabled": false,
            "serviceAccountsEnabled": false,
            "redirectUris": [
                "http://localhost:4200/*",
                "${ZEV_FRONTEND_URL:http://localhost:4200}/*"
            ],
            "webOrigins": [
                "http://localhost:4200",
                "${ZEV_FRONTEND_URL:http://localhost:4200}"
            ],
            "attributes": {
                "pkce.code.challenge.method": "S256"
            },
            "defaultClientScopes": [
                "openid",
                "profile",
                "email",
                "roles",
                "web-origins"
            ],
            "optionalClientScopes": [
                "organization"
            ]
        }
    ],
    "users": [
        {
            "username": "user",
            "enabled": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "password"
                }
            ],
            "realmRoles": [
                "zev_user"
            ]
        },
        {
            "username": "testuser",
            "enabled": true,
            "emailVerified": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "testpassword"
                }
            ],
            "realmRoles": [
                "zev_admin"
            ]
        },
        {
            "username": "orgadmin",
            "enabled": true,
            "emailVerified": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "orgadminpassword"
                }
            ],
            "realmRoles": [
                "org_admin"
            ]
        }
    ],
    "roles": {
        "realm": [
            {
                "name": "einheit:read",
                "description": "Einheiten lesen (Liste)"
            },
            {
                "name": "einheit:write",
                "description": "Einheiten anlegen/bearbeiten/loeschen, KI-Matching"
            },
            {
                "name": "messwerte:read",
                "description": "Messwerte lesen (Grafik)"
            },
            {
                "name": "messwerte:write",
                "description": "Messwerte-Upload und Solarverteilung berechnen"
            },
            {
                "name": "statistik:read",
                "description": "Statistik ansehen und PDF-Export"
            },
            {
                "name": "translations:read",
                "description": "Uebersetzungen lesen (i18n-Laufzeit)"
            },
            {
                "name": "translations:manage",
                "description": "Uebersetzungen verwalten (Editor)"
            },
            {
                "name": "tarife:manage",
                "description": "Tarife verwalten"
            },
            {
                "name": "mieter:read",
                "description": "Mieter lesen (z.B. fuer Debitor-Formular)"
            },
            {
                "name": "mieter:manage",
                "description": "Mieter verwalten"
            },
            {
                "name": "debitoren:manage",
                "description": "Debitorenkontrolle verwalten"
            },
            {
                "name": "rechnungen:manage",
                "description": "Rechnungen generieren und herunterladen"
            },
            {
                "name": "einstellungen:write",
                "description": "Einstellungen (Rechnungsangaben) bearbeiten"
            },
            {
                "name": "featureflags:read",
                "description": "Effektive Feature-Flags lesen (UI-Steuerung)"
            },
            {
                "name": "featureflags:manage",
                "description": "Feature-Flags verwalten"
            },
            {
                "name": "lizenzen:read",
                "description": "Lizenzen ansehen"
            },
            {
                "name": "datenbank:read",
                "description": "Datenbank-Ansicht (generische, read-only Tabellenansicht) - nur zev_admin"
            },
            {
                "name": "zev_user",
                "description": "ZEV Member role: Lesezugriff + Rechnungen/Debitoren verwalten (Composite)",
                "composite": true,
                "composites": {
                    "realm": [
                        "einheit:read",
                        "messwerte:read",
                        "statistik:read",
                        "translations:read",
                        "featureflags:read",
                        "lizenzen:read",
                        "mieter:read",
                        "rechnungen:manage",
                        "debitoren:manage"
                    ]
                }
            },
            {
                "name": "org_admin",
                "description": "Organisation Admin role: zev_user + Einstellungen, Einheiten, Messwerte, Tarife, Mieter (keine Uebersetzungen/Feature-Flags)",
                "composite": true,
                "composites": {
                    "realm": [
                        "zev_user",
                        "einstellungen:write",
                        "einheit:write",
                        "messwerte:write",
                        "tarife:manage",
                        "mieter:manage"
                    ]
                }
            },
            {
                "name": "zev_admin",
                "description": "ZEV Admin role: org_admin + Uebersetzungen + Feature-Flags (alle Permissions)",
                "composite": true,
                "composites": {
                    "realm": [
                        "org_admin",
                        "translations:manage",
                        "featureflags:manage",
                        "datenbank:read"
                    ]
                }
            }
        ]
    }
}
