{
  "name": "frontend-service",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "generate-licenses": "node scripts/generate-licenses.js",
    "prebuild": "npm run generate-licenses",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --coverage",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=list",
    "e2e:ui": "playwright test --ui"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@zev/design-system": "file:../design-system",
    "chart.js": "4.5.1",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^25.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.18",
    "@angular/cli": "^21.2.18",
    "@angular/compiler-cli": "^21.2.17",
    "@playwright/test": "^1.58.0",
    "@types/keycloak-js": "^2.5.4",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.9"
  }
}
