# ZEV Pi-Gateway – Broker-Zugangsdaten (Secrets)
#
# Diese Datei NICHT ins Repo committen. Auf dem Pi als root-only Datei ablegen
# (siehe README / systemd EnvironmentFile=/etc/pi-gateway.env):
#   sudo chmod 600 /etc/pi-gateway.env && sudo chown root:root /etc/pi-gateway.env
#
# In config.yaml werden diese Werte über ${MQTT_USERNAME} / ${MQTT_PASSWORD}
# referenziert (keine Secrets in der Konfigurationsdatei selbst).

MQTT_USERNAME=pi-org42
MQTT_PASSWORD=change-me
