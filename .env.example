# ZEV Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key for AI-based unit matching
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Grafana Admin
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Basic Auth fuer die Actuator-Endpoints (/actuator/**) von backend-/admin-/frontend-service.
# Der Spring Boot Admin Server nutzt diese Credentials, um Details (Environment, Logger, ...)
# der registrierten Services abzurufen. Defaults nur fuer lokale Entwicklung – auf NAS/Prod aendern!
ACTUATOR_USER=actuator
ACTUATOR_PASSWORD=actuator

# Basic Auth fuer die Spring-Boot-Admin-UI (http://localhost:8081) und die
# Client-Registrierung (POST /instances). Defaults nur fuer lokale Entwicklung!
SBA_USER=sba
SBA_PASSWORD=sba

# NVD API Key fuer OWASP Dependency-Check (scripts/owasp-dependency-check.ps1)
# Kostenlos anfordern: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
